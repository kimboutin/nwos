      {
        "rows": 4,
        "description": "Shorter paragraph below the collage.",
        "name": "aboutText",
        "type": "text",
        "title": "About Paragraph"
      },
      {
        "description": "Photos for the auto-scrolling slideshow. Add as many as you like.",
