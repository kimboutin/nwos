            "type": "image"
          }
        ],
        "name": "galleryImages",
        "type": "array"
      }
    ],
    "name": "whoWeAre",
    "type": "document"
  },
  {
    "fields": [
      {
        "validation": [
          {
            "level": "error",
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              }
            ]
          }
        ],
        "name": "title",
        "type": "string"
      },
      {
        "validation": [
          {
            "level": "error",
            "rules": [
              {
                "flag": "presence",
                "constraint": "required"
              },
              {
                "flag": "min",
                "constraint": 2000
              }
            ]
          }
        ],
        "name": "year",
        "type": "number"
      },
      {
        "name": "startDate",
        "type": "date"
      },
      {
        "name": "endDate",
        "type": "date"
      },
      {
        "options": {
          "list": [
            {
              "title": "Upcoming",
              "value": "upcoming"
            },
            {
              "title": "Past",
              "value": "past"
            }
          ],
          "layout": "radio"
        },
        "validation": [
          {
            "level": "error",
            "rules": [
              {
                "flag": "valid",
                "constraint": [
                  "upcoming",
                  "past"
                ]
              },
              {
                "flag": "presence",
                "constraint": "required"
              }
            ]
          }
        ],
        "name": "status",
        "type": "string"
      },
      {
        "rows": 4,
        "description": "Paragraph displayed below the aftermovie.",
        "name": "overviewDescription",
        "type": "text"
      },
      {
        "options": {
          "accept": "video/*"
        },
        "description": "Upload the aftermovie video file (MP4 recommended).",
        "name": "aftermovie",
        "type": "file"
      },
      {
        "options": {
          "hotspot": true
        },
        "description": "Thumbnail shown before the user presses play.",
        "name": "aftermoviePoster",
        "type": "image"
      }
